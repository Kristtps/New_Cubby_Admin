{
  "rewrites": [
    {
      "source": "/login",
      "destination": "/pages/login.html"
    },
    {
      "source": "/dashboard",
      "destination": "/pages/index.html"
    },
    {
      "source": "/lockers",
      "destination": "/pages/lockers.html"
    },
    {
      "source": "/customers",
      "destination": "/pages/customers.html"
    },
    {
      "source": "/transactions",
      "destination": "/pages/transactions.html"
    },
    {
      "source": "/rentals",
      "destination": "/pages/rentals.html"
    },
    {
      "source": "/rates",
      "destination": "/pages/rates.html"
    },
    {
      "source": "/reports",
      "destination": "/pages/reports.html"
    },
    {
      "source": "/auditlog",
      "destination": "/pages/auditlog.html"
    },
    {
      "source": "/feedback",
      "destination": "/pages/feedback.html"
    },
    {
      "source": "/profile",
      "destination": "/pages/profile.html"
    },
    {
      "source": "/notifications",
      "destination": "/pages/notifications.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
